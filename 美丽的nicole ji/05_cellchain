<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CellChain Logistics</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --brand: #0099cc;
  --brand-dark: #006fa3;
  --brand-light: #e6f6fb;
  --brand-mid: #b3e0f2;
  --text-primary: #1a1a2e;
  --text-secondary: #555;
  --text-muted: #888;
  --white: #fff;
  --bg: #fff;
  --bg-soft: #f8fbfd;
  --border: #e0eef4;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Noto Sans JP', sans-serif;
  font-weight: 300;
  background: var(--bg);
  color: var(--text-primary);
  line-height: 1.8;
  overflow-x: hidden;
}

header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  animation: slideDown 0.5s ease both;
}
nav {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40px; height: 72px;
}
.logo {
  font-family: 'Montserrat', sans-serif;
  font-weight: 600; font-size: 1.2rem;
  color: var(--text-primary); text-decoration: none;
}
.logo span { color: var(--brand); }
.nav-links { display: flex; gap: 2.5rem; list-style: none; align-items: center; }
.nav-links a {
  font-size: 0.85rem; font-weight: 400;
  color: var(--text-secondary); text-decoration: none;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--brand); }
.nav-cta {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.82rem; font-weight: 500;
  color: var(--brand); border: 1.5px solid var(--brand);
  padding: 0.5rem 1.4rem; border-radius: 2px;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.nav-cta:hover { background: var(--brand); color: #fff; }

/* HERO */
.hero {
  padding-top: 72px; min-height: 100vh;
  position: relative; display: flex; align-items: center;
  overflow: hidden; background: var(--bg);
}
.hero-bg-shape {
  position: absolute; right: 0; top: 0; bottom: 0; width: 52%;
  background: var(--brand-light);
  clip-path: polygon(12% 0%, 100% 0%, 100% 100%, 0% 100%);
  z-index: 0;
}
.hero-bg-shape2 {
  position: absolute; right: 0; top: 0; bottom: 0; width: 48%;
  background: rgba(0,153,204,0.06);
  clip-path: polygon(18% 0%, 100% 0%, 100% 100%, 6% 100%);
  z-index: 0;
}
.hero-inner {
  position: relative; z-index: 1;
  max-width: 1200px; margin: 0 auto; padding: 0 40px;
  width: 100%;
  display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
}
.hero-text { animation: fadeUp 0.8s 0.1s ease both; }
.hero-eyebrow {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.15em;
  color: var(--brand); text-transform: uppercase;
  margin-bottom: 1.2rem;
  display: flex; align-items: center; gap: 10px;
}
.hero-eyebrow::before {
  content: ''; display: block;
  width: 28px; height: 1.5px; background: var(--brand);
}
.hero h1 {
  font-size: clamp(1.9rem, 3.2vw, 2.7rem);
  font-weight: 700; line-height: 1.5;
  color: var(--text-primary); margin-bottom: 1.5rem;
}
.hero h1 em { font-style: normal; color: var(--brand); }
.hero-sub {
  font-size: 0.92rem; line-height: 1.9;
  color: var(--text-secondary); margin-bottom: 2.5rem; max-width: 460px;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn-fill {
  font-family: 'Montserrat', sans-serif;
  background: var(--brand); color: #fff;
  padding: 0.8rem 2rem; border-radius: 2px;
  font-size: 0.82rem; font-weight: 500; letter-spacing: 0.06em;
  text-decoration: none; border: none; cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.btn-fill:hover { background: var(--brand-dark); transform: translateY(-2px); }
.btn-outline {
  font-family: 'Montserrat', sans-serif;
  background: transparent; color: var(--brand);
  padding: 0.8rem 2rem; border-radius: 2px;
  font-size: 0.82rem; font-weight: 500; letter-spacing: 0.06em;
  text-decoration: none; border: 1.5px solid var(--brand);
  transition: background 0.2s;
}
.btn-outline:hover { background: var(--brand-light); }

/* hero panels */
.hero-visual { animation: fadeIn 1s 0.4s ease both; }
.slant-wrap {
  display: flex; gap: 8px; height: 460px;
  transform: skewX(-5deg); border-radius: 6px; overflow: hidden;
}
.sp {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 16px;
  border-radius: 4px; transition: flex 0.4s ease;
  cursor: default;
}
.sp:hover { flex: 1.5; }
.sp:nth-child(1) { background: linear-gradient(160deg,#bee8f7,#9dd6ef); }
.sp:nth-child(2) { background: linear-gradient(160deg,#cceef8,#aadff3); }
.sp:nth-child(3) { background: linear-gradient(160deg,#daf4fc,#bbe8f6); }
.sp svg { width: 36px; height: 36px; color: var(--brand-dark); opacity: 0.75; transform: skewX(5deg); }
.sp-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.68rem; font-weight: 600; letter-spacing: 0.1em;
  color: var(--brand-dark); text-transform: uppercase;
  writing-mode: vertical-rl; transform: rotate(180deg) skewX(5deg);
}

/* SECTION COMMON */
.wrap { max-width: 1200px; margin: 0 auto; padding: 0 40px; }
.en-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.15em;
  color: var(--brand); text-transform: uppercase; margin-bottom: 0.6rem;
}
.sec-title {
  font-size: clamp(1.5rem, 2.4vw, 2rem);
  font-weight: 700; color: var(--text-primary); line-height: 1.4;
  margin-bottom: 1rem;
}
.sec-desc {
  font-size: 0.9rem; color: var(--text-secondary);
  line-height: 1.85; max-width: 580px;
}

/* MISSION */
.mission { padding: 100px 0; }
.mission-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 6rem; align-items: center;
}
.mission-body p {
  font-size: 0.92rem; color: var(--text-secondary);
  line-height: 1.9; margin-bottom: 1.1rem;
}
.mission-body p strong { color: var(--text-primary); font-weight: 500; }
.mission-photos { position: relative; }
.photo-panels {
  display: flex; gap: 6px; height: 380px;
  transform: skewX(-5deg); border-radius: 4px; overflow: hidden;
}
.pp {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 12px;
  transition: flex 0.35s ease; cursor: default;
}
.pp:hover { flex: 1.4; }
.pp:nth-child(1) { background: linear-gradient(160deg,#c8e9f5,#a0d6ec); }
.pp:nth-child(2) { background: linear-gradient(160deg,#d4eef8,#b3e2f3); }
.pp:nth-child(3) { background: linear-gradient(160deg,#ddf3fb,#c0e9f6); }
.pp:nth-child(4) { background: linear-gradient(160deg,#e8f7fc,#cfedfa); }
.pp svg { width: 28px; height: 28px; color: var(--brand); opacity: 0.6; transform: skewX(5deg); }
.pp span {
  font-size: 0.62rem; color: var(--brand-dark); font-weight: 500;
  writing-mode: vertical-rl; transform: rotate(180deg) skewX(5deg);
  letter-spacing: 0.05em;
}

/* SOLUTIONS */
.solutions { padding: 100px 0; background: var(--bg-soft); }
.sol-grid {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem;
  margin-top: 3rem;
}
.sol-card {
  background: var(--white); border: 1px solid var(--border);
  border-radius: 4px; padding: 2.2rem 2rem;
  position: relative; overflow: hidden;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
}
.sol-card::after {
  content: ''; position: absolute;
  top: 0; left: 0; right: 0; height: 3px;
  background: var(--brand);
  transform: scaleX(0); transform-origin: left; transition: transform 0.3s;
}
.sol-card:hover { transform: translateY(-6px); box-shadow: 0 8px 32px rgba(0,153,204,0.1); border-color: var(--brand-mid); }
.sol-card:hover::after { transform: scaleX(1); }
.sol-num {
  font-family: 'Montserrat', sans-serif;
  font-size: 2.4rem; font-weight: 700;
  color: var(--brand-mid); line-height: 1; margin-bottom: 1rem;
}
.sol-icon {
  width: 48px; height: 48px; border-radius: 50%;
  background: var(--brand-light);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.2rem;
}
.sol-icon svg { width: 22px; height: 22px; color: var(--brand); }
.sol-card h3 {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.05rem; font-weight: 600; color: var(--brand); margin-bottom: 0.25rem;
}
.sol-sub { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.9rem; }
.sol-card p { font-size: 0.87rem; color: var(--text-secondary); line-height: 1.8; }

/* NUMBERS */
.numbers {
  padding: 80px 0; background: var(--brand);
  position: relative; overflow: hidden;
}
.numbers::before {
  content: ''; position: absolute; inset: 0;
  background: repeating-linear-gradient(
    -55deg, transparent, transparent 20px,
    rgba(255,255,255,0.03) 20px, rgba(255,255,255,0.03) 21px
  );
}
.nums-grid {
  position: relative; z-index: 1;
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 2rem; text-align: center;
}
.ni { color: #fff; }
.ni-val {
  font-family: 'Montserrat', sans-serif;
  font-size: 2.8rem; font-weight: 700; line-height: 1; margin-bottom: 0.5rem;
}
.ni-val sup { font-size: 1.1rem; vertical-align: super; }
.ni-label { font-size: 0.8rem; opacity: 0.8; letter-spacing: 0.04em; }

/* FLOW */
.flow { padding: 100px 0; }
.flow-grid {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 0; position: relative; margin-top: 3.5rem;
}
.flow-grid::after {
  content: ''; position: absolute;
  top: 35px; left: 10%; right: 10%;
  height: 1px; background: var(--border);
}
.fs {
  text-align: center; padding: 0 1rem;
  display: flex; flex-direction: column; align-items: center; gap: 1rem;
}
.fc {
  width: 70px; height: 70px; border-radius: 50%;
  background: var(--bg);
  border: 2px solid var(--brand-mid);
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 1;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.72rem; font-weight: 600; color: var(--brand);
  letter-spacing: 0.04em;
  transition: background 0.3s, border-color 0.3s, color 0.3s;
}
.fs:hover .fc { background: var(--brand); border-color: var(--brand); color: #fff; }
.fs h4 { font-size: 0.88rem; font-weight: 700; color: var(--text-primary); }
.fs p { font-size: 0.8rem; color: var(--text-muted); line-height: 1.7; }

/* CTA */
.cta { padding: 100px 0; background: var(--bg-soft); }
.cta-box {
  background: var(--white); border: 1px solid var(--border);
  border-radius: 4px; padding: 4rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start;
}
.cta-l h2 { font-size: 1.5rem; font-weight: 700; line-height: 1.6; margin-bottom: 1rem; }
.cta-l p { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.85; }
.cta-r { display: flex; flex-direction: column; gap: 0.7rem; }
.row2 { display: flex; gap: 0.7rem; }
.cta-r input, .cta-r textarea {
  background: var(--bg-soft); border: 1px solid var(--border);
  padding: 0.75rem 1rem; font-size: 0.87rem;
  font-family: 'Noto Sans JP', sans-serif;
  color: var(--text-primary); border-radius: 2px; outline: none;
  transition: border-color 0.2s; width: 100%;
}
.cta-r input:focus, .cta-r textarea:focus { border-color: var(--brand); }
.cta-r textarea { resize: none; height: 100px; }
.submit-btn {
  align-self: flex-start;
  font-family: 'Montserrat', sans-serif;
  background: var(--brand); color: #fff;
  padding: 0.85rem 2.5rem; border-radius: 2px;
  font-size: 0.8rem; font-weight: 500; letter-spacing: 0.08em;
  text-transform: uppercase; border: none; cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.submit-btn:hover { background: var(--brand-dark); transform: translateY(-2px); }

/* FOOTER */
footer { background: #0d1b2a; padding: 3.5rem 0 0; }
.footer-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 40px 2.5rem;
  display: flex; justify-content: space-between; align-items: flex-start;
  gap: 3rem; flex-wrap: wrap;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.footer-brand .logo { color: #fff; }
.footer-brand p {
  font-size: 0.78rem; color: rgba(255,255,255,0.38);
  margin-top: 0.8rem; line-height: 1.7; max-width: 240px;
}
.footer-cols { display: flex; gap: 4rem; }
.footer-col h5 {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.68rem; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(255,255,255,0.5);
  margin-bottom: 1rem;
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.footer-col a {
  font-size: 0.82rem; color: rgba(255,255,255,0.35);
  text-decoration: none; transition: color 0.2s;
}
.footer-col a:hover { color: var(--brand); }
.footer-bottom {
  max-width: 1200px; margin: 0 auto;
  padding: 1.2rem 40px;
  font-size: 0.72rem; color: rgba(255,255,255,0.2);
  display: flex; justify-content: space-between;
}

/* SCROLL REVEAL */
.reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
.reveal.in { opacity: 1; transform: none; }
.rl { opacity: 0; transform: translateX(-28px); transition: opacity 0.7s ease, transform 0.7s ease; }
.rl.in { opacity: 1; transform: none; }
.rr { opacity: 0; transform: translateX(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
.rr.in { opacity: 1; transform: none; }

@keyframes slideDown { from { opacity:0; transform:translateY(-14px); } to { opacity:1; transform:none; } }
@keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:none; } }
@keyframes fadeIn { from { opacity:0; } to { opacity:1; } }

@media (max-width: 900px) {
  .hero-inner, .mission-grid, .cta-box { grid-template-columns: 1fr; }
  .hero-visual { display: none; }
  .sol-grid { grid-template-columns: 1fr 1fr; }
  .nums-grid { grid-template-columns: repeat(2,1fr); }
  .flow-grid { grid-template-columns: repeat(2,1fr); }
  .flow-grid::after { display: none; }
  nav .nav-links { display: none; }
}
@media (max-width: 600px) {
  .sol-grid { grid-template-columns: 1fr; }
  .row2 { flex-direction: column; }
  .footer-cols { flex-direction: column; gap: 2rem; }
}
</style>
</head>
<body>

<header>
  <nav>
    <a href="#" class="logo">Cell<span>Chain</span> Logistics</a>
    <ul class="nav-links">
      <li><a href="#mission">Mission</a></li>
      <li><a href="#solutions">Solutions</a></li>
      <li><a href="#flow">Flow</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
    <a href="#contact" class="nav-cta">お問い合わせ</a>
  </nav>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg-shape"></div>
  <div class="hero-bg-shape2"></div>
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-eyebrow">Cell Therapy Logistics</div>
      <h1>
        細胞という命の素材を、<br>
        <em>正確に</em>、<em>安全に</em>、<br>
        世界へ届ける。
      </h1>
      <p class="hero-sub">
        再生医療の普及を「輸送」の側面から支えるCellChain Logistics。
        極低温・定温・輸送支援の3つのソリューションで、
        世界中の細胞治療プロジェクトを支援します。
      </p>
      <div class="hero-actions">
        <a href="#solutions" class="btn-fill">ソリューションを見る</a>
        <a href="#contact" class="btn-outline">お問い合わせ</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="slant-wrap">
        <div class="sp">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2z"/><path d="M8 12s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          <div class="sp-label">CryoWing</div>
        </div>
        <div class="sp">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14.76V3.5a2.5 2.5 0 00-5 0v11.26a4.5 4.5 0 105 0z"/></svg>
          <div class="sp-label">ThermoSure</div>
        </div>
        <div class="sp">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div class="sp-label">CellPass</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MISSION -->
<section class="mission" id="mission">
  <div class="wrap">
    <div class="mission-grid">
      <div class="rl">
        <div class="en-label">Mission</div>
        <h2 class="sec-title">Cellchainの使命</h2>
        <div class="mission-body" style="margin-top:1.5rem">
          <p>再生医療が普及する時代において、最も足りていないのは「輸送」です。</p>
          <p>CellChain Logisticsは、細胞という命の素材を、<strong>最適な温度・時間・制度のもとに届けるための専門ブランド</strong>です。</p>
          <p>CryoWing（極低温輸送）、ThermoSure（定温輸送）、CellPass（輸送支援）の3つのソリューションを通じて、世界中の再生医療プロジェクトを支えます。</p>
        </div>
      </div>
      <div class="rr mission-photos">
        <div class="photo-panels">
          <div class="pp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
            <span>現場スタッフ</span>
          </div>
          <div class="pp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 014-4h4a4 4 0 014 4v2"/></svg>
            <span>研究者</span>
          </div>
          <div class="pp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.64A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <span>サポート</span>
          </div>
          <div class="pp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            <span>グローバル</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SOLUTIONS -->
<section class="solutions" id="solutions">
  <div class="wrap">
    <div class="reveal">
      <div class="en-label">Solutions</div>
      <h2 class="sec-title">3つのソリューション</h2>
      <p class="sec-desc">細胞の種類・輸送距離・規制要件に応じた最適なサービスを提供します。</p>
    </div>
    <div class="sol-grid">
      <div class="sol-card reveal">
        <div class="sol-num">01</div>
        <div class="sol-icon">
